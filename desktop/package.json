{
  "name": "desktop",
  "private": true,
  "version": "0.0.34",
  "description": "Time Tracker desktop app (Electron, Windows)",
  "author": "RDZ Tile Group",
  "main": "main.js",
  "scripts": {
    "dev": "cross-env TT_DEV_URL=http://localhost:5173 electron .",
    "start": "electron .",
    "build": "electron-builder --win nsis"
  },
  "dependencies": {
    "uiohook-napi": "^1.5.4",
    "electron-updater": "^6.3.9",
    "get-windows": "^9.2.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^32.1.2",
    "electron-builder": "24.13.3"
  },
  "build": {
    "appId": "net.rdztilegroup.timetracker",
    "productName": "Time Tracker",
    "electronVersion": "32.3.3",
    "artifactName": "TimeTracker-Setup-${version}.${ext}",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*"
    ],
    "extraResources": [
      { "from": "../web/dist", "to": "web" }
    ],
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.ico"
    },
    "publish": [
      { "provider": "github", "owner": "CARRERSRTG", "repo": "timetracker" }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
